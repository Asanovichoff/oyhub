{
  "title": "OyHub",
  "uid": "oyhub-main",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Tool call rate (per tool)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (tool) (rate(oyhub_tool_calls_total[5m]))",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Avg tool latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "1000 * sum by (tool) (rate(oyhub_tool_call_duration_seconds_sum[5m])) / sum by (tool) (rate(oyhub_tool_calls_total[5m]))",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(oyhub_tool_calls_total{status=\"error\"}[5m]))",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "Skills in library",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [{ "expr": "oyhub_skills_total" }]
    },
    {
      "id": 5,
      "title": "Logged messages",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [{ "expr": "oyhub_logged_messages_total" }]
    }
  ]
}
